# === Database Configuration ===
# Get this from Supabase Dashboard -> Project Settings -> Database -> Connection string (URI)
# Make sure to replace [YOUR-PASSWORD] with your actual database password
DATABASE_URL="postgresql://postgres.yourproject:password@aws-0-us-west-1.pooler.supabase.com:6543/postgres"

# Required for /api/resume/* JWT validation. Same as frontend VITE_SUPABASE_URL.
SUPABASE_URL="https://your-project-ref.supabase.co"
# Optional fallback: backend also reads VITE_SUPABASE_URL if SUPABASE_URL is unset.

# === LLM Provider Configuration ===
# Which AI provider to use for generation (options: "openai", "google", "vertex", "ollama")
LLM_PROVIDER="openai"

# Which AI provider to use for embeddings (options: "openai", "google", "vertex", "ollama")
EMBEDDINGS_PROVIDER="openai"

# === API Keys (Fill out based on the chosen providers above) ===

# OpenAI (Get from https://platform.openai.com/api-keys)
OPENAI_API_KEY="sk-..."
# Default models (Optional to set):
# OPENAI_MODEL="gpt-4o-mini"
# OPENAI_EMBED_MODEL="text-embedding-3-small"

# Gemini / Google Studio (Get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY="AIza..."

# --- Apify: All Jobs Scraper (Cloud Run Job / scripts/daily_apify_backfill.py) ---
# APIFY_TOKEN=apify_api_xxxxx
# JOBS_BACKFILL_KEYWORDS=Software Engineer,Data Engineer,Product Manager
# JOBS_BACKFILL_COUNTRY=United States
# JOBS_BACKFILL_LOCATION=
# JOBS_BACKFILL_MAX_RESULTS_PER_KEYWORD=60
# JOBS_BACKFILL_MAX_TOTAL_CHARGE_USD=5
# JOBS_BACKFILL_POSTED_SINCE=7 days
# JOBS_BACKFILL_JOB_TYPE=all
# JOBS_BACKFILL_REMOTE_ONLY=false
# JOBS_BACKFILL_REPLACE_ALL=false
# JOBS_BACKFILL_TIMEOUT_SEC=300

# === CORS & Server Settings ===
# URL of your frontend for local development
CORS_ORIGINS="http://localhost:5173"

# --- Contact form (POST /api/contact → Resend) ---
# https://resend.com/api-keys — add domain or use onboarding@resend.dev for testing
# RESEND_API_KEY=re_xxxx
# CONTACT_EMAIL_TO=annikap@synergyers.com
# CONTACT_EMAIL_FROM=Recrux <onboarding@resend.dev>
