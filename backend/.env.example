# === Database Configuration ===
# Get this from Supabase Dashboard -> Project Settings -> Database -> Connection string (URI)
# Make sure to replace [YOUR-PASSWORD] with your actual database password
DATABASE_URL="postgresql://postgres.yourproject:password@aws-0-us-west-1.pooler.supabase.com:6543/postgres"

# Required for /api/resume/* JWT validation. Same as frontend VITE_SUPABASE_URL.
SUPABASE_URL="https://your-project-ref.supabase.co"
# Optional fallback: backend also reads VITE_SUPABASE_URL if SUPABASE_URL is unset.

# === LLM Provider Configuration ===
# Which AI provider to use for generation (options: "openai", "google", "vertex", "ollama")
LLM_PROVIDER="openai"

# Which AI provider to use for embeddings (options: "openai", "google", "vertex", "ollama")
EMBEDDINGS_PROVIDER="openai"

# === API Keys (Fill out based on the chosen providers above) ===

# OpenAI (Get from https://platform.openai.com/api-keys)
OPENAI_API_KEY="sk-..."
# Default models (Optional to set):
# OPENAI_MODEL="gpt-4o-mini"
# OPENAI_EMBED_MODEL="text-embedding-3-small"

# Gemini / Google Studio (Get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY="AIza..."

# Job Search APIs (Optional, primarily for JSearch Agent)
# Get from RapidAPI -> JSearch API (https://rapidapi.com/letscrape-6bRBa3QG1q/api/jsearch)
RAPIDAPI_KEY="your-rapidapi-key"

# === CORS & Server Settings ===
# URL of your frontend for local development
CORS_ORIGINS="http://localhost:5173"
