# Copy this file to .env and fill in real values (never commit .env)
# cp .env.example .env

# --- Supabase (auth, profiles, storage) ---
# Dashboard: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Apify: All Jobs Scraper (live job listings on /jobs & dashboard fallback) ---
# Free Apify account: https://apify.com/pricing → Console → Settings → Integrations → API token
# Actor: https://apify.com/agentx/all-jobs-scraper (pay-per-event; small runs fit free monthly credits)
VITE_APIFY_TOKEN=your_apify_api_token_here
# Optional: default country for searches — must be an exact Apify label, e.g. United States, Canada, United Kingdom
# (not USA/US). See APIFY_ALLOWED_COUNTRIES in src/lib/apifyAllJobs.ts
# VITE_JOBS_SEARCH_COUNTRY=United States

# --- Backend API (resume parse, jobs RAG, chat) ---
# Local `npm run dev`: requests use /api + Vite proxy → localhost:8001; VITE_API_URL is ignored unless:
# VITE_API_DIRECT=true
# Production build: set to your HTTPS Cloud Run URL.
VITE_API_URL=http://localhost:8001
# VITE_API_DIRECT=true

# --- Contact page (mailto + copy; change per environment) ---
# VITE_CONTACT_EMAIL=annikap@synergyers.com
