VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backend API (FastAPI) - resume parse, job search, job score
VITE_API_URL=http://localhost:8000

# NOTE: Backend keys (GEMINI_API_KEY, etc.) go in backend/.env only — never in frontend
