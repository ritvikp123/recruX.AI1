# Copy this file to .env and fill in real values (never commit .env)
# cp .env.example .env

# --- Supabase (auth, profiles, storage) ---
# Dashboard: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- JSearch on RapidAPI (live job listings) ---
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch → Subscribe → copy "X-RapidAPI-Key"
VITE_RAPIDAPI_KEY=your_rapidapi_key_here

# Optional alias (same value as VITE_RAPIDAPI_KEY if you prefer this name)
# VITE_JSEARCH_API_KEY=

# --- Backend API (resume parse, jobs RAG, chat) ---
# Local: same port as uvicorn (this repo uses 8001).
VITE_API_URL=http://localhost:8001
# Production (Vercel/Netlify): HTTPS Cloud Run URL, e.g. https://recruix-backend-xxxxx-uc.a.run.app
